# Provider: "anthropic" or "openai"
PROVIDER=anthropic

# ── Anthropic ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── OpenAI ─────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Known working OpenAI models (tool calling + JSON output):
#   gpt-4o-mini     ← default, best price/quality
#   gpt-4o
#   gpt-3.5-turbo   ← works but may produce weaker JSON; set TEMPERATURE=0
#   o3-mini         ← reasoning model; tool calls supported but slower
#
# Models NOT recommended:
#   gpt-3.5-turbo-instruct  ← completion-only, no tool calls

# ── Token budgets ───────────────────────────────────────────────
# MAX_TOKENS       — used by planner / evaluator / constraint checker
# CODE_MAX_TOKENS  — used by the software engineer agent (needs more room)
MAX_TOKENS=2048
CODE_MAX_TOKENS=4096

# ── Sampling ────────────────────────────────────────────────────
# 0 = most deterministic JSON; raise to 0.3–0.7 for creative tasks
# Weaker models (gpt-3.5) benefit most from TEMPERATURE=0
TEMPERATURE=0
